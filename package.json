{
  "name": "epub-builder",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:version": "node scripts/sync-version.mjs",
    "build": "pnpm run sync:version && vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "tauri": "pnpm run sync:version && tauri",
    "td": "pnpm run sync:version && tauri dev",
    "tb": "pnpm run sync:version && tauri build --bundles msi && explorer src-tauri\\target\\release\\bundle\\msi || exit 0",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@iconify-json/carbon": "^1.2.20",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@unocss/preset-attributify": "^66.6.8",
    "@unocss/preset-icons": "^66.6.8",
    "@unocss/preset-uno": "^66.6.8",
    "@zip.js/zip.js": "^2.8.26",
    "codemirror": "^6.0.2",
    "dexie": "^4.4.2",
    "docx": "^9.6.1",
    "epub-gen-memory": "^1.1.2",
    "highlight.js": "^11.11.1",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "naive-ui": "^2.44.1",
    "path-browserify": "^1.0.1",
    "pdfjs-dist": "^5.7.284",
    "pinia": "^3.0.4",
    "turndown": "^7.2.4",
    "unocss": "^66.6.8",
    "vue": "^3.5.33",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/path-browserify": "^1.0.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "happy-dom": "^20.9.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
