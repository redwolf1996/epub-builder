{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "EPUB Builder",
  "version": "0.1.0",
  "identifier": "com.epub-builder",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3401",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -Command \"& 'src-tauri\\ocr\\build-sidecar.ps1'; pnpm build\""
  },
  "app": {
    "windows": [
      {
        "title": "EPUB Builder - Best Way From Markdown To Epub",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "center": true,
        "maximized": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; font-src 'self' data:; connect-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "resources": [
      "ocr/dist/rapidocr-sidecar",
      "ocr/sidecar.py",
      "ocr/corrections.json",
      "ocr/build-sidecar.ps1",
      "ocr/requirements.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
